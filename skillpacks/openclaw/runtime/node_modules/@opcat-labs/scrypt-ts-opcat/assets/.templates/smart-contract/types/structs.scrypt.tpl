
struct TxOut {
  bytes scriptHash;
  bytes dataHash;
  int satoshis;
}

struct TxIn {
  bytes prevTxHash;
  int prevOutputIndex;
  int sequence;
  bytes scriptHash;
}

struct TxHashPreimage {
  bytes version;
  bytes inputList;
  bytes outputList;
  bytes nLockTime;
}

struct BacktraceInfo {
  TxIn prevTxInput;
  int prevTxInputIndex;
  TxHashPreimage prevPrevTxPreimage;
}

struct SHPreimage {
  bytes nVersion;
  bytes hashPrevouts;
  int inputIndex;
  bytes outpoint;
  bytes spentScriptHash;
  bytes spentDataHash;
  int value;
  bytes nSequence;
  bytes hashSpentAmounts;
  bytes hashSpentScriptHashes;
  bytes hashSpentDataHashes;
  bytes hashSequences;
  bytes hashOutputs;
  int nLockTime;
  int sigHashType;
}

struct Outpoint {
  bytes txHash;
  int outputIndex;
}

struct ChangeInfo {
  Ripemd160 pubkeyhash;
  int satoshis;
  Sha256 dataHash;
}
