import "txUtils.scrypt";
import "contextUtils.scrypt";




contract _opcat_labs_scrypt_ts_opcat_4_0_0__rs__P2PKH {
  const Ripemd160 addr;
  public function unlock(Sig sig, PubKey pubkey) {
    require(hash160(pubkey) == this.addr);
    require((sig[len(sig) - 1 : ] == num2bin(1, 2)[0 : 1] && num2bin(1, 2)[1 : ] == b'00' && checkSig(sig, pubkey)));
  }
}